# Supabase Configuration
# Get these from your Supabase dashboard: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_URL=https://your_project_id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key_here

# Backend API URL
# Development: http://localhost:3000
# Production:  https://your-backend.railway.app  (or Render/Fly.io URL)
VITE_BACKEND_URL=http://localhost:3000
