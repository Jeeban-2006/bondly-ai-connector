# Supabase Configuration
# Get these from your Supabase dashboard: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_URL=https://your_project_id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key_here

# Optional: If you want to use OpenAI features from frontend (not recommended)
# It's better to call backend API which handles OpenAI on server-side
# VITE_OPENAI_API_KEY=sk-your_openai_key_here
